  "fixed_sql": [
    {
      "name": "pokemon_species",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pokemon_species\" (\"id\" INTEGER NOT NULL, \"identifier\" TEXT NOT NULL, \"generation_id\" INTEGER NOT NULL, \"evolves_from_species_id\" INTEGER NULL, \"evolution_chain_id\" INTEGER NULL, \"color_id\" INTEGER NOT NULL, \"shape_id\" INTEGER NULL, \"habitat_id\" INTEGER NULL, \"gender_rate\" INTEGER NOT NULL, \"capture_rate\" INTEGER NOT NULL, \"base_happiness\" INTEGER NULL, \"is_baby\" INTEGER NOT NULL CHECK (\"is_baby\" IN (0, 1)), \"hatch_counter\" INTEGER NULL, \"has_gender_differences\" INTEGER NOT NULL CHECK (\"has_gender_differences\" IN (0, 1)), \"growth_rate_id\" INTEGER NOT NULL, \"forms_switchable\" INTEGER NOT NULL CHECK (\"forms_switchable\" IN (0, 1)), \"is_legendary\" INTEGER NOT NULL CHECK (\"is_legendary\" IN (0, 1)), \"is_mythical\" INTEGER NOT NULL CHECK (\"is_mythical\" IN (0, 1)), \"order\" INTEGER NOT NULL, \"conquest_order\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "pokemon_species_names",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pokemon_species_names\" (\"pokemon_species_id\" INTEGER NOT NULL REFERENCES pokemon_species (id), \"local_language_id\" INTEGER NOT NULL, \"name\" TEXT NOT NULL, \"genus\" TEXT NULL, PRIMARY KEY (\"pokemon_species_id\", \"local_language_id\"));"
        }
      ]
    },
    {
      "name": "pokemon",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pokemon\" (\"id\" INTEGER NOT NULL, \"identifier\" TEXT NOT NULL, \"species_id\" INTEGER NOT NULL REFERENCES pokemon_species (id), \"height\" INTEGER NOT NULL, \"weight\" INTEGER NOT NULL, \"base_experience\" INTEGER NULL, \"order\" INTEGER NOT NULL, \"is_default\" INTEGER NOT NULL CHECK (\"is_default\" IN (0, 1)), PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "types",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"types\" (\"id\" INTEGER NOT NULL, \"identifier\" TEXT NOT NULL, \"generation_id\" INTEGER NOT NULL, \"damage_class_id\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "pokemon_types",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pokemon_types\" (\"pokemon_id\" INTEGER NOT NULL REFERENCES pokemon (id), \"type_id\" INTEGER NOT NULL REFERENCES types (id), \"slot\" INTEGER NOT NULL, PRIMARY KEY (\"pokemon_id\", \"slot\"));"
        }
      ]
    },
    {
      "name": "stats",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"stats\" (\"id\" INTEGER NOT NULL, \"damage_class_id\" INTEGER NULL, \"identifier\" TEXT NOT NULL, \"is_battle_only\" INTEGER NOT NULL CHECK (\"is_battle_only\" IN (0, 1)), \"game_index\" INTEGER NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "pokemon_stats",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pokemon_stats\" (\"pokemon_id\" INTEGER NOT NULL REFERENCES pokemon (id), \"stat_id\" INTEGER NOT NULL REFERENCES stats (id), \"base_stat\" INTEGER NOT NULL, \"effort\" INTEGER NOT NULL, PRIMARY KEY (\"pokemon_id\", \"stat_id\"));"
        }
      ]
    },
    {
      "name": "abilities",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"abilities\" (\"id\" INTEGER NOT NULL, \"identifier\" TEXT NOT NULL, \"generation_id\" INTEGER NOT NULL, \"is_main_series\" INTEGER NOT NULL CHECK (\"is_main_series\" IN (0, 1)), PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "pokemon_abilities",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pokemon_abilities\" (\"pokemon_id\" INTEGER NOT NULL REFERENCES pokemon (id), \"ability_id\" INTEGER NOT NULL REFERENCES abilities (id), \"is_hidden\" INTEGER NOT NULL CHECK (\"is_hidden\" IN (0, 1)), \"slot\" INTEGER NOT NULL, PRIMARY KEY (\"pokemon_id\", \"slot\"));"
        }
      ]
    },

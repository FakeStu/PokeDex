        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"moves\" (\"id\" INTEGER NOT NULL, \"identifier\" TEXT NOT NULL, \"generation_id\" INTEGER NOT NULL, \"type_id\" INTEGER NOT NULL REFERENCES types (id), \"power\" INTEGER NULL, \"pp\" INTEGER NULL, \"accuracy\" INTEGER NULL, \"priority\" INTEGER NOT NULL, \"target_id\" INTEGER NOT NULL, \"damage_class_id\" INTEGER NOT NULL, \"effect_id\" INTEGER NULL, \"effect_chance\" INTEGER NULL, \"contest_type_id\" INTEGER NULL, \"contest_effect_id\" INTEGER NULL, \"super_contest_effect_id\" INTEGER NULL, PRIMARY KEY (\"id\"));"
